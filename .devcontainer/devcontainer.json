{
  "name": "Market Alert Hub (compose)",
  "dockerComposeFile": [
    "../ops/dev/docker-compose.base.yml"
  ],
  "service": "api",
  "runServices": [
    "db",
    "redis",
    "api",
    "worker",
    "dispatcher",
    "collector",
    "gateway"
  ],
  "workspaceFolder": "/app",
  "shutdownAction": "none", // stopCompose
  "overrideCommand": false,
  "postCreateCommand": "alembic upgrade head || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "openai.chatgpt",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "python.createEnvironment.trigger": "off",
        "python.terminal.activateEnvironment": false,
        "python.analysis.indexing": false
      }
    }
  }
}