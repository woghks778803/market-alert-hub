{
  "name": "Market Alert Hub (compose)",
  "dockerComposeFile": ["../ops/dev/docker-compose.base.yml"],
  "service": "api",                             
  "runServices": ["db", "redis", "api", "worker", "collector", "gateway"],
  // "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind,consistency=cached",
  "workspaceFolder": "/app",
  "shutdownAction": "none", // stopCompose
  "overrideCommand": false,
  "postCreateCommand": "alembic upgrade head || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "njpwerner.autodocstring",
        "ms-python.black-formatter",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "redis.redis-for-vscode",
        "humao.rest-client",
        "rangav.vscode-thunder-client",
        "redhat.vscode-yaml",
        "arjun.swagger-viewer"
      ]
    }
  }
}
